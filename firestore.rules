rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserRole() == role;
    }

    function isModerator() {
      return isAuthenticated()
        && getUserRole() in ['moderator', 'admin', 'super_admin'];
    }

    function isAdmin() {
      return isAuthenticated()
        && getUserRole() in ['admin', 'super_admin'];
    }

    function isSuperAdmin() {
      return hasRole('super_admin');
    }

    // Users
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Listings
    match /listings/{listingId} {
      allow read: if true;

      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid
        && (request.resource.data.status == 'pendiente' || isAdmin());

      allow update: if isOwner(resource.data.ownerId)
        && (
          // Normal edit: cannot change moderation fields
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'moderatorId', 'moderatedAt'])
            // Resubmit for review: can set status back to pendiente
            || request.resource.data.status == 'pendiente'
            // Allow updating availability status
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['availabilityStatus', 'updatedAt'])
        )
        // Allow anyone to increment view count
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']))
        || isModerator();

      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Suggested Categories
    match /suggestedCategories/{sugId} {
      allow read: if isModerator();
      allow create: if isAuthenticated();
      allow update: if isModerator();
      allow delete: if isAdmin();
    }

    // Reports
    match /reports/{reportId} {
      allow read: if isModerator();
      allow create: if isAuthenticated();
      allow update: if isModerator();
      allow delete: if isAdmin();
    }

    // Rental Requests
    match /rentalRequests/{requestId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated()
        && request.resource.data.renterId == request.auth.uid
        && request.resource.data.status == 'pendiente';
      
      allow update: if isAuthenticated()
        && (
          // Listing owners can approve/reject requests for their listings
          get(/databases/$(database)/documents/listings/$(resource.data.listingId)).data.ownerId == request.auth.uid
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
          // Admins can update any request
          || isModerator()
        );
      
      allow delete: if isModerator();
    }
  }
}
