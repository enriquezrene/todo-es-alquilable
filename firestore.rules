rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }

    function isModerator() {
      return hasRole('moderator') || hasRole('admin') || hasRole('super_admin');
    }

    function isAdmin() {
      return hasRole('admin') || hasRole('super_admin');
    }

    function isSuperAdmin() {
      return hasRole('super_admin');
    }

    // Users
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Listings
    match /listings/{listingId} {
      allow read: if true;

      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.status == 'pendiente';

      allow update: if isOwner(resource.data.ownerId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'moderatorId', 'moderatedAt'])
        || isModerator();

      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Suggested Categories
    match /suggestedCategories/{sugId} {
      allow read: if isModerator();
      allow create: if isAuthenticated();
      allow update: if isModerator();
      allow delete: if isAdmin();
    }

    // Reports
    match /reports/{reportId} {
      allow read: if isModerator();
      allow create: if isAuthenticated();
      allow update: if isModerator();
      allow delete: if isAdmin();
    }
  }
}
